    "@vue/tsconfig": "^0.4.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "vue-tsc": "^1.8.11",
    "@types/node": "^20.5.9",
    "eslint": "^8.48.0",
    "eslint-plugin-vue": "^9.17.0",
    "@typescript-eslint/parser": "^6.5.0",
    "@typescript-eslint/eslint-plugin": "^6.5.0",
